<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ToolbarStyle">
        <item name="android:background">?attr/colorPrimary</item>
        <item name="android:backgroundTint">?attr/colorPrimary</item>
        <item name="navigationIcon">?attr/homeAsUpIndicator</item>
        <item name="navigationIconTint">@color/back_button</item>
    </style>

    <style name="ToolbarTitleTextAppearanceStyle" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:fontFamily">@font/ys_display_medium</item>
    </style>

    <style name="MainFontStyle">
        <item name="android:fontFamily">@font/ys_display_medium</item>
    </style>

    <style name="MainButtonStyle" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:backgroundTint">@color/white</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">@dimen/main_font_size</item>
        <item name="cornerRadius">@dimen/main_corner_radius</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">@dimen/main_icon_padding</item>
        <item name="iconTint">@color/black</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
    </style>

    <style name="SettingsIconStyle">
        <item name="android:backgroundTint">?attr/colorPrimary</item>
    </style>

    <style name="SettingsTextViewStyle">
        <item name="android:textColor">?attr/colorOnBackground</item>
        <item name="android:textSize">@dimen/settings_font_size</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
    </style>

    <style name="TrackTextStyle">
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:lines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="TrackTitleStyle" parent="TrackTextStyle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/track_title_size</item>
    </style>

    <style name="TrackSubtitleStyle" parent="TrackTextStyle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/track_subtitle_size</item>
    </style>

    <style name="SearchMessage">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/search_msg</item>
        <item name="android:textSize">19sp</item>
    </style>

    <style name="SearchButton">
        <item name="android:backgroundTint">@color/button_background</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:maxLines">1</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/reload_button_text</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">54dp</item>
    </style>

    <style name="PlayerControlButtonStyle">
        <item name="android:layout_width">51dp</item>
        <item name="android:layout_height">51dp</item>
        <item name="android:background">@drawable/round_button</item>
        <item name="android:tint">@color/white</item>
    </style>

    <style name="PlayerTextStyle">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="PlayerTrackNameStyle" parent="PlayerTextStyle">
        <item name="android:textSize">22sp</item>
    </style>

    <style name="PlayerArtistNameStyle" parent="PlayerTextStyle">
        <item name="android:textSize">14sp</item>
    </style>

    <style name="PlayerTimerStyle" parent="PlayerTextStyle">
        <item name="android:textSize">14sp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="PlayerInfoStyle">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:paddingTop">9dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <style name="PlayerInfoLabelStyle" parent="PlayerInfoStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="PlayerInfoValueStyle" parent="PlayerInfoStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:gravity">end</item>
        <item name="android:ellipsize">end</item>
        <item name="android:singleLine">true</item>
    </style>

</resources>
